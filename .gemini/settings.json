{
  "theme": "Default",
  "selectedAuthType": "oauth-personal",

  "model": "gemini-2.5-pro",

  "coreTools": [
    "read_file",
    "write_file",
    "list_directory",
    "run_shell_command",
    "search_file_content",
    "web_fetch",
    "web_search"
  ],

  "mcpServers": {
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      },
      "description": "GitHub MCP — list PRs, issues, commits, create branches"
    },
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "."
      ],
      "description": "Full filesystem access to the project root"
    },
    "fetch": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-fetch"],
      "description": "HTTP fetch for reading docs, API responses"
    }
  },

  "contextFileName": "GEMINI.md",

  "autoAccept": false,

  "telemetry": {
    "enabled": false
  },

  "checkpointing": {
    "enabled": true
  },

  "tokenCache": {
    "enabled": true
  }
}
